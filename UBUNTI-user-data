#cloud-config
autoinstall:
  version: 1

  locale: en_US.UTF-8

  keyboard:
    layout: us

  timezone: Asia/Kolkata

  refresh-installer:
    update: false

  identity:
    hostname: ubuntu
    username: admin
    password: "$6$f2CqqSxlPrXgSilb$giAfpuh7ZKf0FoP0Qw5cmQk/uAB6Cnuazd/2UVB4f6V8Tq36HttTdpcw9/IDm5G5efKeDhowjpfdEFS9JRRSl0"

  apt:
    fallback: offline-install
    preserve_sources_list: false
    mirror-selection:
      primary:
        - arches: [amd64]
          uri: http://ubuntu.com

  ssh:
    install-server: true
    allow-pw: true
    authorized-keys: []

  network:
    version: 2
    ethernets:
      vmnic:
        match:
          name: "en*" # MAXIMUM PORTABILITY: Dynamically captures ens32, enp2s0, or ens160 safely
        dhcp4: true
        dhcp6: false
        dhcp-identifier: mac # Tracks leases strictly by hardware MAC to prevent address collision stalls
        optional: true # Bypasses network service-wait execution blocks during failover

  packages:
    - open-vm-tools
    - curl
    - wget
    - vim
    - mdadm
    - lvm2

  storage:
    config:
      # ----------------------------
      # Disk 1
      # ----------------------------
      - id: disk-sda
        type: disk
        match:
          path: /dev/sda
        ptable: gpt
        wipe: superblock-recursive
        preserve: false
        grub_device: true # Primary system NVRAM registration target

      # ----------------------------
      # Disk 2
      # ----------------------------
      - id: disk-sdb
        type: disk
        match:
          path: /dev/sdb
        ptable: gpt
        wipe: superblock-recursive
        preserve: false

      # ---------- EFI Partition Elements ----------
      - id: sda-efi
        type: partition
        device: disk-sda
        size: 512M
        flag: boot
        grub_device: true # Maps primary boot variables onto sda1

      - id: sdb-efi
        type: partition
        device: disk-sdb
        size: 512M
        flag: boot

      # ---------- /boot Partition Elements ----------
      - id: sda-boot
        type: partition
        device: disk-sda
        size: 2G

      - id: sdb-boot
        type: partition
        device: disk-sdb
        size: 2G

      # ---------- LVM Physical Volumes ----------
      - id: sda-lvm
        type: partition
        device: disk-sda
        size: 96G

      - id: sdb-lvm
        type: partition
        device: disk-sdb
        size: 96G

      # ---------- RAID /boot ----------
      - id: md0
        type: raid
        name: md0
        raidlevel: raid1
        metadata: "1.0" # Keeps metadata signatures highly visible for early-stage UEFI boot loops
        devices:
          - sda-boot
          - sdb-boot

      # ---------- RAID PV ----------
      - id: md1
        type: raid
        name: md1
        raidlevel: raid1
        metadata: "1.2"
        devices:
          - sda-lvm
          - sdb-lvm

      # ---------- LVM Volume Group ----------
      - id: vg0
        type: lvm_volgroup
        name: ubuntu-vg
        devices:
          - md1

      # ---------- Swap Logical Volume ----------
      - id: lv-swap
        type: lvm_partition
        name: swap
        volgroup: vg0
        size: 8G

      # ---------- Root Logical Volume ----------
      - id: lv-root
        type: lvm_partition
        name: root
        volgroup: vg0

      # ---------- Format Filesystems ----------
      - id: fmt-efi1
        type: format
        volume: sda-efi
        fstype: fat32

      - id: fmt-efi2
        type: format
        volume: sdb-efi
        fstype: fat32

      - id: fmt-boot
        type: format
        volume: md0
        fstype: ext4

      - id: fmt-root
        type: format
        volume: lv-root
        fstype: ext4

      - id: fmt-swap
        type: format
        volume: lv-swap
        fstype: swap

      # ---------- Mount Points ----------
      - id: mnt-root
        type: mount
        device: fmt-root
        path: /

      - id: mnt-boot
        type: mount
        device: fmt-boot
        path: /boot

      - id: mnt-efi
        type: mount
        device: fmt-efi1
        path: /boot/efi

  late-commands:
    - curtin in-target -- apt-get clean
    - curtin in-target -- cloud-init clean --logs
    - curtin in-target -- rm -f /etc/cloud/cloud-init.disabled
    - curtin in-target -- rm -rf /var/lib/systemd/netif
    - curtin in-target -- rm -rf /var/lib/dhcp
    - curtin in-target -- truncate -s 0 /etc/machine-id
    - curtin in-target -- rm -f /var/lib/dbus/machine-id

    # Disable cloud-init networking
    - curtin in-target -- mkdir -p /etc/cloud/cloud.cfg.d
    - curtin in-target -- wget -O /etc/cloud/cloud.cfg.d/99-disable-network-config.cfg http://192.168.253.136/repo/scripts/99-disable-network-config.cfg

    # Download Netplan configuration
    - curtin in-target -- mkdir -p /etc/netplan
    - curtin in-target -- wget -O /etc/netplan/01-netcfg.yaml http://192.168.253.136/repo/scripts/01-netcfg.yaml
    - curtin in-target -- chmod 600 /etc/netplan/01-netcfg.yaml

    # Download EFI sync script
    - curtin in-target -- mkdir -p /usr/local/sbin
    - curtin in-target -- wget -O /usr/local/sbin/sync-efi.sh http://192.168.253.136/repo/scripts/sync-efi.sh
    - curtin in-target -- chmod 755 /usr/local/sbin/sync-efi.sh

    # Download systemd service
    - curtin in-target -- wget -O /etc/systemd/system/sync-efi.service http://192.168.253.136/repo/scripts/sync-efi.service

    # Enable service
    - curtin in-target -- systemctl daemon-reload
    - curtin in-target -- systemctl enable sync-efi.service

    # Enable passwordless sudo for admin
    - curtin in-target -- bash -c 'echo "admin ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/99-admin'
    - curtin in-target -- chmod 440 /etc/sudoers.d/99-admin

    # Make EFI mount non-fatal if primary disk is missing
    - curtin in-target -- sed -i 's/defaults/umask=0077,nofail,x-systemd.device-timeout=2/' /etc/fstab	
    # Regenerate initramfs
    - curtin in-target -- update-initramfs -u

    # Regenerate GRUB configuration
    - curtin in-target -- update-grub
